[Unit]
Description=ACC shared filesystem (Samba/SMB)
After=network-online.target
Wants=network-online.target

[Mount]
What=//AGENT_SMB_HOST/AGENT_SMB_SHARE
Where=AGENT_HOME/.acc/shared
Type=cifs
Options=credentials=/etc/samba/smbcredentials,uid=AGENT_UID,gid=AGENT_GID,file_mode=0664,dir_mode=0775,_netdev,vers=3.0,nofail

[Install]
WantedBy=multi-user.target
