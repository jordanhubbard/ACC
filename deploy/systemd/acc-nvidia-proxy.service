[Unit]
Description=ACC NVIDIA Header-Stripping Proxy (anthropic-beta compat)
Documentation=https://github.com/{OWNER}/CCC
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=AGENT_USER
EnvironmentFile=-AGENT_HOME/.acc/.env
Environment=PATH=AGENT_HOME/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=AGENT_HOME/.acc/bin/acc-agent proxy --port 9099
Restart=always
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
