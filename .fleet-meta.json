{
  "version": 1,
  "description": "CCC fleet metadata — source of truth for agent software management",
  "updated": "2026-04-09",

  "hermes-agent": {
    "repo": "git@github.com:jordanhubbard/hermes-agent.git",
    "repo_https": "https://github.com/jordanhubbard/hermes-agent.git",
    "upstream": "https://github.com/NousResearch/hermes-agent.git",
    "branch": "main",
    "feature_branches": ["feature/multi-workspace-socket-mode"],
    "install_path": "~/.hermes/hermes-agent",
    "note": "All CCC agents use jordanhubbard/hermes-agent fork, NOT NousResearch upstream. The fork has multi-workspace Slack Socket Mode and CCC-specific patches.",

    "update_commands": [
      "cd ~/.hermes/hermes-agent && git fetch origin",
      "cd ~/.hermes/hermes-agent && git checkout main",
      "cd ~/.hermes/hermes-agent && git pull --ff-only origin main",
      "cd ~/.hermes/hermes-agent && pip install -e '.[all]' --quiet"
    ],

    "post_update": [
      "hermes gateway restart slack"
    ]
  },

  "ccc": {
    "repo": "git@github.com:jordanhubbard/CCC.git",
    "branch": "main",
    "install_path": "~/Src/CCC",
    "minio_bucket": "clawfs",
    "minio_prefix": "agents/shared/CCC/",
    "note": "Central Command and Control — shared codebase for all agents"
  },

  "agents": {
    "natasha": {
      "host": "sparky (DGX Spark)",
      "tailscale_ip": "100.89.199.14",
      "platform": "slack",
      "home": "/home/jkh"
    },
    "rocky": {
      "host": "do-host1 (DigitalOcean VPS)",
      "tailscale_ip": "100.89.199.14",
      "platform": "slack",
      "home": "/home/jkh",
      "note": "Hosts ClawBus, MinIO, CCC API"
    },
    "bullwinkle": {
      "host": "puck (Mac)",
      "platform": "slack",
      "home": "/Users/jkh"
    }
  },

  "clawbus": {
    "hub": "http://146.190.134.110:8789",
    "bus_send": "/api/bus/send",
    "bus_stream": "/api/bus/stream",
    "update_type": "rcc.update"
  }
}
